# EcoAlign-Forge Configuration
# Copy to .env and fill in your values

# --- LLM Provider (via LiteLLM) ---
OPENAI_API_KEY=sk-your-openai-key
OPENAI_API_BASE=https://api.openai.com/v1

# Agent Model Assignment (GPT-5.4 priority)
CHAOS_CREATOR_MODEL=openai/gpt-5.4-mini
MODERATOR_MODEL=openai/gpt-5.4-mini
JUDGE_MODEL=openai/gpt-5.4

# --- Synthesis Defaults ---
DEFAULT_BATCH_SIZE=10
DEFAULT_MAX_CONCURRENT=5
DEFAULT_TEMPERATURE=0.7

# --- 解析校验重试（解析失败时重新发起整次 LLM 调用）---
PARSE_MAX_RETRIES=3
PARSE_RETRY_WAIT_MIN=1
PARSE_RETRY_WAIT_MAX=10

# --- Storage ---
DATA_DIR=./data
DATASETS_DIR=./data/datasets

# --- Dashboard ---
DASHBOARD_REFRESH_INTERVAL=5000
